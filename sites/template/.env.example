# ==========================================
# 站点配置（复制为 .env 后修改）
# ==========================================

# 站点URL（不要带末尾斜杠）
PUBLIC_SITE_URL=https://your-domain.com

# 站点名称
PUBLIC_SITE_NAME=变现学堂

# ==========================================
# Analytics 配置
# ==========================================

# Google Analytics (可选)
# PUBLIC_GA_ID=G-XXXXXXXXXX

# 百度统计 (可选)
# PUBLIC_BAIDU_TONGJI=your-id

# Umami Analytics (可选)
# PUBLIC_UMAMI_URL=https://umami.example.com
# PUBLIC_UMAMI_ID=xxxxx

# ==========================================
# Cloudflare (可选)
# ==========================================

# Cloudflare Analytics Token
# CF_ANALYTICS_TOKEN=xxxxx
