---
import { AdBanner, BaseLayout, BlogCard } from '@astro-money-farm/core/components';
import siteConfig from '../../config';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) =>
  b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const categories = [...new Set(allPosts.map(p => p.data.category))];
const tags = [...new Set(allPosts.flatMap(p => p.data.tags || []))];
---

<BaseLayout config={siteConfig} title="全部文章 | 变现学堂" description="浏览博客所有文章，探索AI变现、副业、法国创业等实用干货。">
  <div class="blog-page">
    <header class="page-header">
      <div class="container">
        <h1 class="page-title">全部文章</h1>
        <p class="page-desc">{sortedPosts.length}篇精选文章</p>
      </div>
    </header>

    <div class="container">
      <!-- Category filters -->
      <aside class="filters">
        <div class="filter-section">
          <h3 class="filter-title">分类</h3>
          <div class="filter-tags">
            {categories.map(cat => (
              <a href={`/blog/category/${cat}`} class="filter-tag">
                {cat}
              </a>
            ))}
          </div>
        </div>

        {tags.length > 0 && (
          <div class="filter-section">
            <h3 class="filter-title">标签</h3>
            <div class="filter-tags">
              {tags.map(t => (
                <a href={`/blog/tag/${t}`} class="filter-tag">
                  #{t}
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>

      <!-- Posts -->
      <main class="posts-section">
        <AdBanner config={siteConfig} position="top" />

        <div class="posts-grid">
          {sortedPosts.map(post => (
            <BlogCard config={siteConfig} post={post} />
          ))}
        </div>

        <AdBanner config={siteConfig} position="inline" />
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-page { padding-bottom: 4rem; }
  .page-header { background: var(--bg-secondary); padding: 3rem 0; margin-bottom: 2rem; }
  .page-title { font-size: 2rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem; }
  .page-desc { font-size: 1rem; color: var(--text-secondary); margin: 0; }

  .filters { margin-bottom: 2rem; padding: 1.5rem; background: var(--bg-secondary); border-radius: 0.75rem; }
  .filter-section { margin-bottom: 1.5rem; }
  .filter-section:last-child { margin-bottom: 0; }
  .filter-title { font-size: 0.9rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.75rem; }
  .filter-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .filter-tag {
    padding: 0.375rem 0.75rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .filter-tag:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
    text-decoration: none;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1024px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .page-title { font-size: 1.5rem; }
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
