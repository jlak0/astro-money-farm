---
import { BaseLayout, FriendLinks } from '@astro-money-farm/core/components';
import siteConfig, { getSiteUrl } from '../config';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const socialConfig = siteConfig.social || {};
const siteUrl = getSiteUrl();
const siteName = siteConfig.site.name;
const contactEmail = socialConfig.email || 'contact@moneyplatform.ai';

const stats = {
  articles: allPosts.length,
  categories: [...new Set(allPosts.map(p => p.data.category))].length,
};
---
<BaseLayout config={siteConfig}
  title="友链 & 站群网络 | 变现学堂"
  description="与优秀站点交换链接，共同成长。变现学堂站群网络，汇聚AI变现、副业创业、法国签证等优质内容。"
>
  <div class="page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">🏠 友链 & 站群网络</h1>
        <p class="page-desc">与优秀站点交换链接，共同成长。加入我们的内容网络，互相引流，共享流量红利。</p>
      </header>

      <div class="stats-bar">
        <div class="stat">
          <span class="stat-num">{stats.articles}</span>
          <span class="stat-label">篇精选文章</span>
        </div>
        <div class="stat">
          <span class="stat-num">{stats.categories}</span>
          <span class="stat-label">个内容分类</span>
        </div>
      </div>

      <section class="apply-section">
        <h2 class="section-title">📮 申请友链</h2>
        <div class="apply-rules">
          <div class="rules-card">
            <h3>友链要求</h3>
            <ul>
              <li>✅ 网站内容合法合规</li>
              <li>✅ 有实质内容，非空壳站点</li>
              <li>✅ 活跃更新（至少每月1篇）</li>
              <li>✅ 与变现/副业/创业/AI 相关主题优先</li>
            </ul>
          </div>
          <div class="rules-card">
            <h3>交换格式</h3>
            <pre class="link-code">{`名称：${siteName}
网址：${siteUrl}
描述：分享AI变现、副业赚钱、法国创业等实战方法
Logo：${siteUrl}/og-default.svg`}</pre>
          </div>
        </div>
        <div class="apply-cta">
          <p>符合要求？联系邮箱：<a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
        </div>
      </section>

      <section class="friend-links-section">
        <FriendLinks config={siteConfig} />
      </section>

      <section class="network-section">
        <h2 class="section-title">🌐 站群网络</h2>
        <p class="network-desc">我们的内容网络覆盖多个细分领域，互相引流，共同增长。</p>
        <div class="network-grid">
          {[...new Set(allPosts.map(p => p.data.category))].map(cat => {
            const catPosts = allPosts.filter(p => p.data.category === cat);
            return (
              <div class="network-item">
                <div class="network-icon">
                  {cat === 'AI变现' && '🤖'}
                  {cat === '副业' && '💰'}
                  {cat === '干货' && '📚'}
                  {cat === '法国创业' && '🇫🇷'}
                  {!['AI变现', '副业', '干货', '法国创业'].includes(cat) && '📌'}
                </div>
                <div class="network-info">
                  <h3>{cat}</h3>
                  <p>{catPosts.length} 篇内容</p>
                </div>
                <a href={`/blog/category/${cat}`} class="network-link">查看 →</a>
              </div>
            );
          })}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .page { padding: 3rem 0 6rem; }
  .container { max-width: 900px; margin: 0 auto; padding: 0 1rem; }

  .page-header { text-align: center; margin-bottom: 2rem; }
  .page-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }
  .page-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-bottom: 3rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
  }
  .stat { text-align: center; }
  .stat-num {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent-color);
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 1rem;
  }

  .apply-section { margin-bottom: 3rem; }
  .apply-rules {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 640px) {
    .apply-rules { grid-template-columns: 1fr; }
  }

  .rules-card {
    padding: 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
  }
  .rules-card h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }
  .rules-card ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .rules-card li {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
    line-height: 1.5;
  }

  .link-code {
    font-size: 0.8rem;
    color: var(--text-secondary);
    background: var(--bg-primary);
    padding: 0.75rem;
    border-radius: 0.375rem;
    overflow-x: auto;
    margin: 0;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .apply-cta {
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .apply-cta a {
    color: var(--accent-color);
    text-decoration: none;
  }
  .apply-cta a:hover { text-decoration: underline; }

  .friend-links-section { margin-bottom: 3rem; }

  .network-section { margin-bottom: 2rem; }
  .network-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
  }
  .network-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }
  .network-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
  }
  .network-icon { font-size: 1.5rem; flex-shrink: 0; }
  .network-info { flex: 1; min-width: 0; }
  .network-info h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 2px;
  }
  .network-info p {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin: 0;
  }
  .network-link {
    font-size: 0.8rem;
    color: var(--accent-color);
    text-decoration: none;
    white-space: nowrap;
  }
  .network-link:hover { text-decoration: underline; }
</style>
