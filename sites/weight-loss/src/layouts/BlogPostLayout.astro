---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import SEO from '../components/SEO.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AdBanner from '../components/AdBanner.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import EmailSubscribe from '../components/EmailSubscribe.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import FriendLinks from '../components/FriendLinks.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import { getCollection } from 'astro:content';
import config from '../config';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, publishDate, modifiedDate, tags, category, author, ogImage } = post.data;

const { Content, headings } = await post.render();

const siteConfig = config as any;
const lang = siteConfig.site?.lang || siteConfig.language || 'zh-CN';

// Locale-aware date formatting
const localeMap: Record<string, string> = {
  'zh-CN': 'zh-CN',
  'en-US': 'en-US',
  'en': 'en-US',
  'zh': 'zh-CN'
};

const dateLocale = localeMap[lang] || 'en-US';
const formattedDate = new Date(publishDate).toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// i18n labels
const labels = {
  'zh-CN': {
    siteName: '变现学堂',
    topAd: '顶部广告',
    desktopToc: '桌面端目录',
    sidebarAd: '侧边栏广告',
    mobileToc: '移动端目录',
    emailSubscribe: '邮箱订阅',
    affiliateTitle: '推荐工具：XXX - 帮你提高10倍效率',
    affiliateDesc: '我自己用了2年,确实大幅提升了工作效率。现在注册还送免费试用。',
    affiliatePlatform: '联盟',
    inlineAd: '文中广告',
    relatedPosts: '相关文章'
  },
  'en-US': {
    siteName: 'FastWeightLoss',
    topAd: 'Advertisement',
    desktopToc: 'Table of Contents',
    sidebarAd: 'Advertisement',
    mobileToc: 'Table of Contents',
    emailSubscribe: 'Newsletter',
    affiliateTitle: 'Recommended Tool: XXX - 10x Your Productivity',
    affiliateDesc: 'I have been using this for 2 years and it has significantly improved my efficiency. Free trial available.',
    affiliatePlatform: 'Sponsored',
    inlineAd: 'Advertisement',
    relatedPosts: 'Related Posts'
  }
};

const t = labels[lang] || labels['zh-CN'];

// Get related posts - tag matching algorithm
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .map(p => {
    const commonTags = p.data.tags?.filter(t => tags?.includes(t)).length || 0;
    const sameCategory = p.data.category === category ? 1 : 0;
    return { post: p, score: commonTags * 2 + sameCategory };
  })
  .filter(item => item.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(item => item.post);
---

<BaseLayout
  title={`${title} | ${t.siteName}`}
  description={description}
  keywords={tags}
  ogType="article"
  ogImage={ogImage}
>
  <ReadingProgress />

  <article class="blog-post" data-pagefind-meta="title:@title, category:@category">
    <!-- Top Ad -->
    <AdBanner position="top" />

    <header class="post-header">
      <div class="container">
        <div class="post-meta">
          <a href={`/blog/category/${category}`} class="post-category">{category}</a>
          <span class="post-date">{formattedDate}</span>
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-tags">
          {tags?.map(tag => (
            <a href={`/blog/tag/${tag}`} class="post-tag">#{tag}</a>
          ))}
        </div>
      </div>
    </header>

    <div class="post-layout">
      <aside class="post-sidebar">
        <!-- Desktop TOC (sticky sidebar) -->
        <div class="desktop-toc">
          <TableOfContents headings={headings} />
        </div>

        <!-- Sidebar Ad -->
        <AdBanner position="sidebar" />
      </aside>

      <div class="post-content">
        <!-- Mobile TOC (collapsible, before content) -->
        <div class="mobile-toc">
          <TableOfContents headings={headings} />
        </div>

        <!-- Email Subscribe -->
        <EmailSubscribe />

        <div class="prose">
          <Content />
        </div>

        <!-- Sample Affiliate Link -->
        <AffiliateLink
          href="https://example.com/affiliate"
          title={t.affiliateTitle}
          description={t.affiliateDesc}
          platform={t.affiliatePlatform}
        />

        <!-- Inline Ad -->
        <AdBanner position="inline" />

        <!-- Related Posts -->
        {relatedPosts.length > 0 && <RelatedPosts posts={relatedPosts} />}
        <FriendLinks />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-bottom: 4rem;
  }

  .post-header {
    background: var(--bg-secondary);
    padding: 3rem 0;
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .post-category {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .post-category:hover {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin: 0 0 1rem;
    max-width: 900px;
  }

  .post-description {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    max-width: 700px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-tag {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    background: var(--bg-primary);
    border-radius: 1rem;
    transition: background 0.2s, color 0.2s;
  }

  .post-tag:hover {
    background: var(--accent-color);
    color: white;
    text-decoration: none;
  }

  .post-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 3rem;
  }

  .post-sidebar {
    position: sticky;
    top: 5rem;
    height: fit-content;
  }

  .desktop-toc {
    display: block;
  }

  .mobile-toc {
    display: none;
  }

  .post-content {
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      position: static;
      display: none;
    }

    .desktop-toc {
      display: none;
    }

    .mobile-toc {
      display: block;
    }

    .post-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 640px) {
    .post-header {
      padding: 2rem 0;
    }

    .post-title {
      font-size: 1.5rem;
    }

    .post-description {
      font-size: 1rem;
    }
  }
</style>
