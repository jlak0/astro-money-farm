---
import config from '../config';

export interface Props {
  href: string;
  title: string;
  description?: string;
  platform?: string;
}

const { href, title, description, platform } = Astro.props;
const affiliateEnabled = config.affiliate?.enabled ?? false;

const siteConfig = config as any;
const lang = siteConfig.site?.lang || siteConfig.language || 'zh-CN';

const labels = {
  'zh-CN': {
    defaultPlatform: '推广',
    disclaimer: '*此链接为联盟链接,我们可能会获得一定佣金'
  },
  'en-US': {
    defaultPlatform: 'Sponsored',
    disclaimer: '*This is an affiliate link. We may earn a commission.'
  }
};

const t = labels[lang] || labels['zh-CN'];
const platformLabel = platform || t.defaultPlatform;
---

{affiliateEnabled && (
  <div class="affiliate-link-card">
  <div class="affiliate-badge">{platformLabel}</div>
  <a href={href} class="affiliate-link" target="_blank" rel="noopener sponsored">
    <div class="affiliate-content">
      <h4 class="affiliate-title">{title}</h4>
      {description && <p class="affiliate-desc">{description}</p>}
    </div>
    <svg class="affiliate-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </a>
  <p class="affiliate-disclaimer">{t.disclaimer}</p>
  </div>
)}

<style>
  .affiliate-link-card {
    background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg-tertiary, var(--bg-secondary)) 100%);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.25rem;
    margin: 1.5rem 0;
    position: relative;
  }

  .affiliate-badge {
    position: absolute;
    top: -0.5rem;
    right: 1rem;
    background: var(--accent-color);
    color: white;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .affiliate-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .affiliate-content {
    flex: 1;
  }

  .affiliate-title {
    margin: 0 0 0.25rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .affiliate-desc {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .affiliate-arrow {
    width: 24px;
    height: 24px;
    color: var(--accent-color);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .affiliate-link:hover .affiliate-arrow {
    transform: translateX(4px);
  }

  .affiliate-disclaimer {
    margin: 0.75rem 0 0;
    font-size: 0.75rem;
    color: var(--text-secondary);
    opacity: 0.8;
  }
</style>
