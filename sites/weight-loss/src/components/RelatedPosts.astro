---
import type { CollectionEntry } from 'astro:content';
import config from '../config';

export interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const siteConfig = config as any;
const lang = siteConfig.site?.lang || siteConfig.language || 'zh-CN';

const labels = {
  'zh-CN': {
    title: '相关文章',
    readMore: '阅读更多 →'
  },
  'en-US': {
    title: 'Related Posts',
    readMore: 'Read More →'
  }
};

const t = labels[lang] || labels['zh-CN'];
---

<section class="related-posts">
  <h3 class="related-title">{t.title}</h3>
  <div class="posts-grid">
    {posts.map(post => (
      <a href={`/blog/${post.slug}`} class="post-card">
        <div class="post-meta">
          {post.data.tags?.slice(0, 2).map(tag => (
            <span class="post-tag">{tag}</span>
          ))}
        </div>
        <h4 class="post-title">{post.data.title}</h4>
        <p class="post-excerpt">{post.data.description}</p>
        <span class="post-read-more">{t.readMore}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .related-posts {
    margin: 3rem 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .related-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 1.5rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .post-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .post-tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: var(--accent-color);
    color: white;
    border-radius: 0.25rem;
    font-weight: 500;
  }

  .post-title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-excerpt {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-read-more {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--accent-color);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
