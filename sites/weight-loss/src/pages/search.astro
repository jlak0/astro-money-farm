---
import { BaseLayout } from '@astro-money-farm/core/components';
import siteConfig, { getLang } from '../config';

const lang = getLang();

const labels = {
  'zh-CN': {
    title: '搜索 | 变现学堂',
    metaDesc: '搜索博客文章，探索AI变现、副业、法国创业等实用干货。',
    pageTitle: '搜索文章',
    pageDesc: '输入关键词找到你感兴趣的内容',
    placeholder: '搜索文章...',
    emptyHint: '输入关键词搜索文章',
    loading: '加载中...',
    loadingFailed: '加载失败',
    searching: '搜索中...',
    dataLoading: '数据加载中...',
    noResults: '没有找到',
    resultCount: '找到 {count} 个结果'
  },
  'en-US': {
    title: 'Search | FastWeightLoss',
    metaDesc: 'Search articles about intermittent fasting, keto diet, and healthy weight loss.',
    pageTitle: 'Search Articles',
    pageDesc: 'Enter keywords to find content you are interested in',
    placeholder: 'Search articles...',
    emptyHint: 'Enter keywords to search',
    loading: 'Loading...',
    loadingFailed: 'Failed to load',
    searching: 'Searching...',
    dataLoading: 'Loading data...',
    noResults: 'No results found for',
    resultCount: 'Found {count} result'
  }
};

const t = labels[lang] || labels['en-US'];
const dateLocale = lang === 'zh-CN' ? 'zh-CN' : 'en-US';
---

<BaseLayout config={siteConfig}
  title={t.title}
  description={t.metaDesc}
>
  <div class="search-page">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">{t.pageTitle}</h1>
        <p class="page-desc">{t.pageDesc}</p>
      </header>

      <div class="search-wrapper">
        <div class="search-box">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            type="search"
            id="search-input"
            class="search-input"
            placeholder={t.placeholder}
            autocomplete="off"
            autofocus
          />
          <span id="search-status" class="search-status"></span>
        </div>
      </div>

      <div id="results" class="results-list"></div>
      <div id="empty-state" class="empty-state">
        <p>{t.emptyHint}</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ t, dateLocale }}>
  // Simple fuzzy search - no external dependencies
  function fuzzySearch(data, query) {
    const q = query.toLowerCase().trim();
    if (!q) return [];

    return data
      .map(item => {
        let score = 0;
        const title = item.title.toLowerCase();
        const desc = item.description.toLowerCase();
        const cat = item.category.toLowerCase();
        const tags = item.tags.join(' ').toLowerCase();

        // Exact title match
        if (title === q) score += 100;
        // Title starts with query
        else if (title.startsWith(q)) score += 50;
        // Title contains query
        else if (title.includes(q)) score += 30;
        // Description contains query
        if (desc.includes(q)) score += 15;
        // Category match
        if (cat === q) score += 20;
        else if (cat.includes(q)) score += 10;
        // Tags match
        if (tags.includes(q)) score += 10;
        // Word-level matching for Chinese
        const qChars = q.split('');
        const titleChars = item.title.toLowerCase();
        const matchedChars = qChars.filter(c => titleChars.includes(c)).length;
        score += matchedChars * 3;

        return { item, score };
      })
      .filter(r => r.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 10);
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function highlight(text, query) {
    if (!query || !text) return escapeHtml(text || '');
    const escaped = escapeHtml(text);
    const q = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const regex = new RegExp(`(${q})`, 'gi');
    return escaped.replace(regex, '<mark>$1</mark>');
  }

  function renderResult(item, query) {
    const date = new Date(item.publishDate).toLocaleDateString(dateLocale, {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
    return `
      <a href="${escapeHtml(item.url)}" class="result-item">
        <div class="result-meta">
          <span class="result-category">${escapeHtml(item.category)}</span>
          <span class="result-date">${date}</span>
        </div>
        <h3 class="result-title">${highlight(item.title, query)}</h3>
        <p class="result-excerpt">${highlight(item.description, query)}</p>
        <div class="result-footer">
          <div class="result-tags">
            ${item.tags.slice(0, 3).map((t) => `<span class="result-tag">${escapeHtml(t)}</span>`).join('')}
          </div>
          <span class="result-reading-time">${item.readingTime || ''}</span>
        </div>
      </a>
    `;
  }

  let searchData = [];
  let debounceTimer = null;

  const input = document.getElementById('search-input');
  const results = document.getElementById('results');
  const emptyState = document.getElementById('empty-state');
  const status = document.getElementById('search-status');

  // Fetch search data on page load
  async function loadSearchData() {
    try {
      status.textContent = t.loading;
      const res = await fetch('/search-index.json');
      if (!res.ok) throw new Error('Failed to load search index');
      searchData = await res.json();
      status.textContent = '';
    } catch (err) {
      console.error('Failed to load search index:', err);
      status.textContent = t.loadingFailed;
    }
  }

  input.addEventListener('input', () => {
    if (debounceTimer) clearTimeout(debounceTimer);
    const query = input.value.trim();

    if (!query) {
      results.innerHTML = '';
      emptyState.style.display = 'block';
      emptyState.querySelector('p').textContent = t.emptyHint;
      status.textContent = '';
      return;
    }

    status.textContent = t.searching;
    debounceTimer = setTimeout(() => {
      if (searchData.length === 0) {
        status.textContent = t.dataLoading;
        loadSearchData().then(() => {
          const searchResults = fuzzySearch(searchData, query);
          renderResults(searchResults, query);
        });
      } else {
        const searchResults = fuzzySearch(searchData, query);
        renderResults(searchResults, query);
      }
    }, 100);
  });

  function renderResults(searchResults, query) {
    if (searchResults.length === 0) {
      results.innerHTML = '';
      emptyState.style.display = 'block';
      emptyState.querySelector('p').textContent = `${t.noResults} "${escapeHtml(query)}"`;
      status.textContent = '';
      return;
    }

    emptyState.style.display = 'none';
    status.textContent = t.resultCount.replace('{count}', searchResults.length);
    results.innerHTML = searchResults.map((r) => renderResult(r.item, query)).join('');
  }

  // Load search data when page loads
  loadSearchData();
</script>

<style is:global>
  .search-page { padding: 3rem 0 6rem; }
  .page-header { text-align: center; margin-bottom: 2.5rem; }
  .page-title { font-size: 2rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem; }
  .page-desc { font-size: 1rem; color: var(--text-secondary); margin: 0; }

  .search-wrapper { max-width: 720px; margin: 0 auto 2rem; }
  .search-box { position: relative; display: flex; align-items: center; }

  .search-icon {
    position: absolute;
    left: 1rem;
    width: 20px;
    height: 20px;
    color: var(--text-secondary);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 1rem 3rem;
    font-size: 1rem;
    color: var(--text-primary);
    background: var(--bg-secondary);
    border: 2px solid var(--border-color);
    border-radius: 0.75rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-input::placeholder { color: var(--text-secondary); }
  .search-input:focus {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }

  .search-status {
    position: absolute;
    right: 1rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .results-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .result-item {
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
    padding: 1.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .result-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .result-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .result-category {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .result-date {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .result-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .result-excerpt {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .result-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }

  .result-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .result-tag {
    font-size: 0.7rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }

  .result-reading-time {
    font-size: 0.8rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  :global(mark) {
    background: rgba(16, 185, 129, 0.2);
    color: var(--accent-color);
    border-radius: 2px;
    padding: 0 2px;
  }

  .empty-state {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem;
    color: var(--text-secondary);
  }

  .empty-state p { margin: 0; font-size: 1.1rem; }
</style>
