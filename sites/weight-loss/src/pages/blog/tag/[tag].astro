---
import { AdBanner, BaseLayout, BlogCard } from '@astro-money-farm/core/components';
import { getCollection } from 'astro:content';
import siteConfig, { getLang } from '../../../config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];
  
  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
    }
  }));
}

const { tag, posts } = Astro.props;

const lang = getLang();

const labels = {
  'zh-CN': {
    siteName: '变现学堂',
    allArticles: '全部文章',
    metaDesc: `浏览所有包含#${tag}标签的文章，探索AI变现、副业、法国创业等实用干货。`,
    articles: '篇文章'
  },
  'en-US': {
    siteName: 'FastWeightLoss',
    allArticles: 'All Articles',
    metaDesc: `Browse all articles tagged with #${tag}. Expert tips on weight loss and healthy living.`,
    articles: 'articles'
  }
};

const t = labels[lang] || labels['zh-CN'];
---

<BaseLayout config={siteConfig} 
  title={`#${tag} | ${t.siteName}`} 
  description={t.metaDesc}
>
  <div class="blog-page">
    <header class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/blog">{t.allArticles}</a>
          <span class="separator">›</span>
          <span class="current">#{tag}</span>
        </nav>
        <h1 class="page-title">#{tag}</h1>
        <p class="page-desc">{posts.length}{t.articles}</p>
      </div>
    </header>

    <div class="container">
      <main class="posts-section">
        <AdBanner config={siteConfig} position="top" />

        <div class="posts-grid">
          {posts.map(post => (
            <BlogCard config={siteConfig} post={post} />
          ))}
        </div>

        <AdBanner config={siteConfig} position="inline" />
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-page { padding-bottom: 4rem; }
  .page-header { background: var(--bg-secondary); padding: 3rem 0; margin-bottom: 2rem; }
  
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }
  .breadcrumb a { color: var(--accent-color); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .separator { margin: 0 0.5rem; }
  .current { color: var(--text-primary); }

  .page-title { font-size: 2rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem; }
  .page-desc { font-size: 1rem; color: var(--text-secondary); margin: 0; }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1024px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .page-title { font-size: 1.5rem; }
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
