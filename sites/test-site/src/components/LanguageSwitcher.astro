---
import config from '../config';

const siteConfig = config as any;
const languages = siteConfig.languages || { default: 'zh-CN', available: ['zh-CN', 'en-US'], showSwitcher: true };
const i18n = siteConfig.i18n || {};

const languageNames: Record<string, string> = {
  'zh-CN': '中文',
  'en-US': 'EN'
};
---

{languages.showSwitcher && (
  <div class="language-switcher">
    <select id="lang-select" class="lang-select">
      {languages.available.map((lang: string) => (
        <option value={lang} selected={lang === languages.default}>
          {languageNames[lang] || lang}
        </option>
      ))}
    </select>
  </div>
)}

<script define:vars={{ i18n }}>
  const select = document.getElementById('lang-select');
  
  // Load saved language preference
  const savedLang = localStorage.getItem('site-language') || 'zh-CN';
  if (select) {
    select.value = savedLang;
    document.documentElement.lang = savedLang;
  }
  
  // Handle language change
  select?.addEventListener('change', (e) => {
    const newLang = e.target.value;
    localStorage.setItem('site-language', newLang);
    document.documentElement.lang = newLang;
    
    // Update all translatable elements
    updatePageLanguage(newLang);
  });
  
  function updatePageLanguage(lang) {
    const translations = i18n[lang] || i18n['zh-CN'];
    
    // Update elements with data-i18n attribute
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      const keys = key.split('.');
      let value = translations;
      for (const k of keys) {
        value = value?.[k];
      }
      if (value) {
        el.textContent = value;
      }
    });
    
    // Dispatch event for other scripts to listen
    window.dispatchEvent(new CustomEvent('languageChanged', { detail: { lang, translations } }));
  }
  
  // Apply saved language on load
  updatePageLanguage(savedLang);
</script>

<style>
  .language-switcher {
    display: flex;
    align-items: center;
  }
  
  .lang-select {
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--border-color);
    border-radius: 0.375rem;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: 0.875rem;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
  }
  
  .lang-select:hover {
    border-color: var(--accent-color);
  }
  
  .lang-select:focus {
    border-color: var(--accent-color);
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);
  }
</style>
