---
import { AdBanner, BaseLayout, BlogCard, Pagination } from '../components';
import type { PaginationMeta } from '../utils';

interface Props {
  config: any;
  category: string;
  posts: any[];
  pagination?: PaginationMeta;
}

const { config, category, posts, pagination } = Astro.props;
const lang = config.site?.lang === 'en-US' || config.language === 'en-US' ? 'en-US' : 'zh-CN';
const siteName = config.site?.name || (lang === 'en-US' ? 'Site' : '站点');
const allArticles = lang === 'en-US' ? 'All Articles' : '全部文章';
const articlesLabel = lang === 'en-US' ? ' articles' : '篇文章';
const paginationLabels = lang === 'en-US'
  ? {
      previous: 'Previous',
      next: 'Next',
      status: 'Page {current} of {total}',
      aria: 'Pagination'
    }
  : {
      previous: '上一页',
      next: '下一页',
      status: '第 {current} / {total} 页',
      aria: '分页导航'
    };
const totalItems = pagination?.totalItems || posts.length;
const description = lang === 'en-US'
  ? `Browse all articles about ${category} from ${siteName}.`
  : `浏览${siteName}中${category}分类的所有文章。`;
---

<BaseLayout config={config} title={`${category} | ${siteName}`} description={description}>
  <div class="blog-page">
    <header class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/blog">{allArticles}</a>
          <span class="separator">›</span>
          <span class="current">{category}</span>
        </nav>
        <h1 class="page-title">{category}</h1>
        <p class="page-desc">{totalItems}{articlesLabel}</p>
      </div>
    </header>

    <div class="container">
      <main class="posts-section">
        <AdBanner config={config} position="top" />
        <div class="posts-grid">
          {posts.map(post => <BlogCard config={config} post={post} />)}
        </div>
        <Pagination
          pagination={pagination}
          previousLabel={paginationLabels.previous}
          nextLabel={paginationLabels.next}
          statusLabel={paginationLabels.status}
          ariaLabel={paginationLabels.aria}
        />
        <AdBanner config={config} position="inline" />
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-page { padding-bottom: 4rem; }
  .page-header { background: var(--bg-secondary); padding: 3rem 0; margin-bottom: 2rem; }
  .breadcrumb { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.75rem; }
  .breadcrumb a { color: var(--accent-color); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .separator { margin: 0 0.5rem; }
  .current { color: var(--text-primary); }
  .page-title { font-size: 2rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem; }
  .page-desc { font-size: 1rem; color: var(--text-secondary); margin: 0; }
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 1024px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .page-title { font-size: 1.5rem; }
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
