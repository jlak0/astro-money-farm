---
import { AdBanner, BaseLayout, BlogCard, EmailSubscribe } from '../components';
import { getCollection } from 'astro:content';
import { deriveCategoryLinks } from '../utils';

const { config } = Astro.props;
const lang = config.site?.lang === 'en-US' || config.language === 'en-US' ? 'en-US' : 'zh-CN';
const siteName = config.site?.name || (lang === 'en-US' ? 'Site' : '站点');

const labels = {
  'zh-CN': {
    startReading: '开始阅读',
    exploreCategories: '探索分类',
    featured: '精选文章',
    categories: '探索分类',
    latestPosts: '最新文章',
    viewAll: '查看全部 →',
    metaTitle: `${siteName} - ${config.site?.description || '博客'}`,
    metaDesc: config.site?.description || `${siteName} 的最新文章`,
    heroDesc: config.site?.description || `来自 ${siteName} 的精选文章。`,
    articleCount: '{count} 篇文章'
  },
  'en-US': {
    startReading: 'Start Reading',
    exploreCategories: 'Explore',
    featured: 'Featured Articles',
    categories: 'Categories',
    latestPosts: 'Latest Posts',
    viewAll: 'View All →',
    metaTitle: `${siteName} - ${config.site?.description || 'Expert Guides'}`,
    metaDesc: config.site?.description || `Expert guides from ${siteName}.`,
    heroDesc: config.site?.description || `Explore practical guides from ${siteName}.`,
    articleCount: '{count} articles'
  }
};

const t = labels[lang];
const home = config.home || {};
const allPosts = await getCollection('blog');
const featuredPosts = allPosts
  .filter(post => post.data.featured)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);

const recentPosts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);

const categories = deriveCategoryLinks(allPosts, config, {
  entries: config.featuredCategories,
  limit: 4
});

const heroTitle = home.heroTitle || siteName;
const heroHighlight = home.heroHighlight;
const heroDescription = home.heroDescription || t.heroDesc;
const primaryCta = home.primaryCta || t.startReading;
const secondaryCta = home.secondaryCta || t.exploreCategories;
const featuredTitle = home.featuredTitle || t.featured;
const categoriesTitle = home.categoriesTitle || t.categories;
const latestTitle = home.latestTitle || t.latestPosts;
const viewAllLabel = home.viewAllLabel || t.viewAll;
const metaTitle = home.metaTitle || t.metaTitle;
const metaDescription = home.metaDescription || t.metaDesc;
---

<BaseLayout config={config} title={metaTitle} description={metaDescription}>
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">
        {heroTitle}
        {heroHighlight && <span class="highlight">{heroHighlight}</span>}
      </h1>
      <p class="hero-desc" set:html={heroDescription} />
      <div class="hero-cta">
        <a href="/blog" class="btn-primary">{primaryCta}</a>
        <a href="#categories" class="btn-secondary">{secondaryCta}</a>
      </div>
    </div>
  </section>

  <AdBanner config={config} position="top" />

  <section class="featured-section">
    <div class="container">
      <h2 class="section-title">{featuredTitle}</h2>
      <div class="featured-grid">
        {featuredPosts.map(post => <BlogCard config={config} post={post} />)}
      </div>
    </div>
  </section>

  <section class="categories-section" id="categories">
    <div class="container">
      <h2 class="section-title">{categoriesTitle}</h2>
      <div class="categories-grid">
        {categories.map(cat => (
          <a href={`/blog/category/${cat.slug}`} class="category-card">
            {cat.icon && <span class="category-icon">{cat.icon}</span>}
            <h3 class="category-name">{cat.name}</h3>
            <p class="category-desc">{cat.description || t.articleCount.replace('{count}', String(cat.count || 0))}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="subscribe-section">
    <div class="container">
      <EmailSubscribe config={config} />
    </div>
  </section>

  <section class="recent-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">{latestTitle}</h2>
        <a href="/blog" class="view-all">{viewAllLabel}</a>
      </div>
      <div class="posts-grid">
        {recentPosts.map(post => <BlogCard config={config} post={post} />)}
      </div>
    </div>
  </section>

  <AdBanner config={config} position="inline" />
</BaseLayout>

<style>
  .hero { padding: 5rem 0; text-align: center; background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%); }
  .hero-title { font-size: 3rem; font-weight: 800; color: var(--text-primary); margin: 0 0 1.5rem; line-height: 1.2; }
  .hero-title .highlight { color: var(--accent-color); }
  .hero-desc { font-size: 1.25rem; color: var(--text-secondary); margin: 0 0 2rem; line-height: 1.7; }
  .hero-cta { display: flex; gap: 1rem; justify-content: center; }
  .btn-primary {
    padding: 0.875rem 2rem;
    background: var(--accent-color);
    color: white;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); text-decoration: none; }
  .btn-secondary {
    padding: 0.875rem 2rem;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-secondary:hover { background: var(--bg-secondary); text-decoration: none; }
  .featured-section,
  .recent-section { padding: 4rem 0; }
  .categories-section { padding: 4rem 0; background: var(--bg-secondary); }
  .section-title { font-size: 1.75rem; font-weight: 700; color: var(--text-primary); margin: 0 0 2rem; }
  .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
  .view-all { color: var(--accent-color); font-weight: 500; text-decoration: none; }
  .view-all:hover { text-decoration: underline; }
  .featured-grid,
  .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .categories-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .category-card {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.5rem;
    text-align: center;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .category-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08); text-decoration: none; }
  .category-icon { font-size: 2.5rem; display: block; margin-bottom: 0.75rem; }
  .category-name { font-size: 1.1rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.5rem; }
  .category-desc { font-size: 0.85rem; color: var(--text-secondary); margin: 0; }
  @media (max-width: 1024px) {
    .featured-grid,
    .posts-grid,
    .categories-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .hero { padding: 3rem 0; }
    .hero-title { font-size: 2rem; }
    .hero-desc { font-size: 1rem; }
    .hero-cta { flex-direction: column; align-items: center; }
    .featured-grid,
    .posts-grid,
    .categories-grid { grid-template-columns: 1fr; }
  }
</style>
