---
import { BaseLayout, EmailSubscribe } from '../components';

const { config } = Astro.props;
const lang = config.site?.lang === 'en-US' || config.language === 'en-US' ? 'en-US' : 'zh-CN';
const siteName = config.site?.name || (lang === 'en-US' ? 'Site' : '站点');
const contactEmail = config.social?.email || (lang === 'en-US' ? 'contact@example.com' : 'contact@example.com');
const about = config.about || {};

const labels = {
  'zh-CN': {
    title: `关于 | ${siteName}`,
    description: `了解${siteName}`,
    pageTitle: '关于',
    sections: [
      {
        title: `关于${siteName}`,
        paragraphs: [
          config.site?.description || `${siteName} 会持续发布实用内容。`
        ]
      }
    ],
    contactTitle: '联系我',
    contactIntro: '如果你有任何问题或合作建议，可以联系我：',
    emailLabel: 'Email：',
    extraContacts: []
  },
  'en-US': {
    title: `About | ${siteName}`,
    description: `Learn about ${siteName}`,
    pageTitle: 'About',
    sections: [
      {
        title: `About ${siteName}`,
        paragraphs: [
          config.site?.description || `${siteName} publishes useful articles and resources.`
        ]
      }
    ],
    contactTitle: 'Contact Me',
    contactIntro: 'For questions or partnerships, contact me:',
    emailLabel: 'Email: ',
    extraContacts: []
  }
};

const t = labels[lang];
const title = about.title || t.title;
const description = about.description || t.description;
const pageTitle = about.pageTitle || t.pageTitle;
const sections = about.sections?.length ? about.sections : t.sections;
const contactTitle = about.contactTitle || t.contactTitle;
const contactIntro = about.contactIntro || t.contactIntro;
const emailLabel = about.emailLabel || t.emailLabel;
const extraContacts = about.extraContacts || t.extraContacts;
---

<BaseLayout config={config} title={title} description={description}>
  <div class="about-page">
    <header class="page-header">
      <div class="container">
        <h1 class="page-title">{pageTitle}</h1>
      </div>
    </header>

    <div class="container">
      <div class="about-content">
        {sections.map(section => (
          <section class="about-section">
            <h2>{section.title}</h2>
            {section.paragraphs?.map(paragraph => <p set:html={paragraph} />)}
            {section.items && (
              <ul>
                {section.items.map(item => <li set:html={item} />)}
              </ul>
            )}
            {section.timeline && (
              <div class="timeline">
                {section.timeline.map(([year, text]) => (
                  <div class="timeline-item">
                    <span class="timeline-year">{year}</span>
                    <p>{text}</p>
                  </div>
                ))}
              </div>
            )}
          </section>
        ))}

        <section class="about-section">
          <h2>{contactTitle}</h2>
          <p>{contactIntro}</p>
          <ul class="contact-list">
            <li>{emailLabel}{contactEmail}</li>
            {extraContacts.map(item => <li>{item}</li>)}
          </ul>
        </section>

        <EmailSubscribe config={config} />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page { padding-bottom: 4rem; }
  .page-header { background: var(--bg-secondary); padding: 3rem 0; margin-bottom: 3rem; }
  .page-title { font-size: 2rem; font-weight: 700; color: var(--text-primary); margin: 0; }
  .about-content { max-width: 720px; margin: 0 auto; }
  .about-section { margin-bottom: 3rem; }
  .about-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent-color);
    display: inline-block;
  }
  .about-section p { color: var(--text-secondary); line-height: 1.8; margin: 0 0 1rem; }
  .about-section ul { list-style: none; padding: 0; margin: 1rem 0; }
  .about-section li { color: var(--text-secondary); padding: 0.5rem 0; padding-left: 1.5rem; position: relative; }
  .about-section li::before { content: '→'; position: absolute; left: 0; color: var(--accent-color); }
  .timeline { margin: 2rem 0; padding-left: 0; list-style: none; }
  .timeline-item { display: flex; gap: 1.5rem; padding: 1rem 0; border-bottom: 1px solid var(--border-color); }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-year { font-weight: 700; color: var(--accent-color); min-width: 50px; }
  .timeline-item p { margin: 0; color: var(--text-secondary); }
  .contact-list { margin-top: 1rem; }
  .contact-list li { padding-left: 0 !important; }
  .contact-list li::before { display: none; }
  @media (max-width: 640px) {
    .page-title { font-size: 1.5rem; }
    .about-section h2 { font-size: 1.25rem; }
  }
</style>
