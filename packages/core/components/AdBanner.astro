---
import defaultConfig, { getLang, type SiteConfig } from '../config';

export interface Props {
  position: 'top' | 'inline' | 'sidebar';
  config?: SiteConfig;
}

const { position, config = defaultConfig } = Astro.props;
const lang = getLang(config);
const labels = {
  'zh-CN': {
    ariaLabel: '广告',
    label: '广告',
    topPlaceholder: '顶部横幅广告位 (728x90)',
    inlinePlaceholder: '文中广告位',
    sidebarPlaceholder: '侧边栏广告位 (300x250)'
  },
  'en-US': {
    ariaLabel: 'Advertisement',
    label: 'Ad',
    topPlaceholder: 'Top Banner Ad (728x90)',
    inlinePlaceholder: 'In-Article Ad',
    sidebarPlaceholder: 'Sidebar Ad (300x250)'
  }
};

const t = labels[lang];

// Check if this ad position is enabled
const adEnabled = config.ads?.enabled && config.ads?.placements?.[position];
---

{adEnabled ? (
  <div class={`ad-banner ad-${position}`} data-position={position}>
    <div class="ad-container">
      <span class="ad-label" aria-label={t.ariaLabel}>{t.label}</span>
      <div class="ad-content">
        {config.ads?.google?.enabled && config.ads?.google?.clientId ? (
          <ins
            class="adsbygoogle"
            data-ad-client={config.ads.google.clientId}
            data-ad-slot={position === 'top' ? config.ads.google.slotTop : position === 'inline' ? config.ads.google.slotInline : config.ads.google.slotSidebar}
            data-ad-format="auto"
            data-full-width-responsive="true"
          />
        ) : (
          <div class="ad-placeholder">
            {position === 'top' && <span>{t.topPlaceholder}</span>}
            {position === 'inline' && <span>{t.inlinePlaceholder}</span>}
            {position === 'sidebar' && <span>{t.sidebarPlaceholder}</span>}
          </div>
        )}
      </div>
    </div>
  </div>
) : null}

<style>
  .ad-banner {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 2rem 0;
  }

  .ad-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .ad-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ad-content {
    border: 1px dashed var(--border-color);
    border-radius: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--bg-secondary);
  }

  .ad-top .ad-content {
    width: 100%;
    max-width: 728px;
    height: 90px;
  }

  .ad-inline .ad-content {
    width: 100%;
    max-width: 650px;
    height: auto;
    min-height: 100px;
    padding: 1rem;
  }

  .ad-sidebar .ad-content {
    width: 300px;
    height: 250px;
  }

  .ad-placeholder {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .ad-top .ad-content {
      max-width: 320px;
      height: 100px;
    }

    .ad-sidebar {
      display: none;
    }
  }
</style>
