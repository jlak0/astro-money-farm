---
import defaultConfig, { getLang, type SiteConfig } from '../config';

export interface Props {
  config?: SiteConfig;
}

const { config = defaultConfig } = Astro.props;
const { name, description } = config.site || { name: '变现学堂', description: '' };
const { copyright, ICP, police } = config.footer || {};
const { email } = config.social || {};
const lang = getLang(config);

const labels = {
  'zh-CN': {
    quickLinks: '快速链接',
    home: '首页',
    allPosts: '全部文章',
    aboutUs: '关于我们',
    categories: '文章分类',
    contact: '联系方式',
    emailContact: 'Email联系',
    sitemap: '网站地图',
    icp: 'ICP备案',
    police: '公安备案',
    footerCategories: [
      'AI变现',
      '副业',
      '干货',
      '法国创业'
    ]
  },
  'en-US': {
    quickLinks: 'Quick Links',
    home: 'Home',
    allPosts: 'All Posts',
    aboutUs: 'About Us',
    categories: 'Categories',
    contact: 'Contact',
    emailContact: 'Email',
    sitemap: 'Sitemap',
    icp: 'ICP',
    police: 'Police',
    footerCategories: [
      'Intermittent Fasting',
      'Keto Diet',
      'Low Carb',
      'Tips'
    ]
  }
};

const t = labels[lang];
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28">
            <circle cx="16" cy="16" r="14" fill="currentColor"/>
            <text x="16" y="21" font-size="14" font-weight="bold" text-anchor="middle" fill="white">$</text>
          </svg>
          <span>{name}</span>
        </a>
        <p class="footer-desc">{description}</p>
      </div>

      <div class="footer-links">
        <div class="footer-column">
          <h4>{t.quickLinks}</h4>
          <ul>
            <li><a href="/">{t.home}</a></li>
            <li><a href="/blog">{t.allPosts}</a></li>
            <li><a href="/about">{t.aboutUs}</a></li>
          </ul>
        </div>

        <div class="footer-column">
          <h4>{t.categories}</h4>
          <ul>
            {t.footerCategories.map(category => (
              <li><a href={`/blog/category/${category}`}>{category}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-column">
          <h4>{t.contact}</h4>
          <ul>
            {email && <li><a href={`mailto:${email}`}>{t.emailContact}</a></li>}
            <li><a href="/sitemap.xml">{t.sitemap}</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        {copyright || `© ${currentYear} ${name}. All rights reserved.`}
        {ICP && <> · <a href={ICP} target="_blank" rel="noopener">{t.icp}</a></>}
        {police && <> · <a href={police} target="_blank" rel="noopener">{t.police}</a></>}
      </p>
      <p>Powered by <a href="https://astro.build" target="_blank" rel="noopener">Astro</a></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: 4rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem 1.5rem;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .footer-logo svg {
    color: var(--accent-color);
  }

  .footer-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-column h4 {
    color: var(--text-primary);
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .footer-column ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-column li {
    margin-bottom: 0.5rem;
  }

  .footer-column a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-column a:hover {
    color: var(--accent-color);
  }

  .footer-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .footer-bottom a {
    color: var(--accent-color);
    text-decoration: none;
  }

  .footer-bottom a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
