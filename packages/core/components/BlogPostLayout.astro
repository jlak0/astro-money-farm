---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AdBanner from '../components/AdBanner.astro';
import EmailSubscribe from '../components/EmailSubscribe.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import FriendLinks from '../components/FriendLinks.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import { getCollection } from 'astro:content';
import defaultConfig, { getLang, type SiteConfig } from '../config';

export interface Props {
  post: CollectionEntry<'blog'>;
  config?: SiteConfig;
}

const { post, config = defaultConfig } = Astro.props;
const { title, description, publishDate, modifiedDate, tags, category, author, ogImage } = post.data;

const { Content, headings } = await post.render();
const lang = getLang(config);
const localeMap: Record<string, string> = {
  'zh-CN': 'zh-CN',
  'en-US': 'en-US'
};
const labels = {
  'zh-CN': {
    siteName: config.site?.name || '站点'
  },
  'en-US': {
    siteName: config.site?.name || 'FastWeightLoss'
  }
};

const t = labels[lang];

// 获取相关文章 - 标签重合度算法
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .map(p => {
    const commonTags = p.data.tags?.filter(t => tags?.includes(t)).length || 0;
    const sameCategory = p.data.category === category ? 1 : 0;
    return { post: p, score: commonTags * 2 + sameCategory };
  })
  .filter(item => item.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(item => item.post);

const formattedDate = new Date(publishDate).toLocaleDateString(localeMap[lang] || 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={`${title} | ${t.siteName}`}
  description={description}
  keywords={tags}
  ogType="article"
  ogImage={ogImage}
  publishDate={publishDate.toISOString()}
  modifiedDate={(modifiedDate || publishDate).toISOString()}
  author={author}
  tags={tags}
  config={config}
>
  <ReadingProgress />

  <article class="blog-post">
    <!-- 顶部广告 -->
    <AdBanner position="top" config={config} />

    <header class="post-header">
      <div class="container">
        <div class="post-meta">
          <a href={`/blog/category/${category}`} class="post-category">{category}</a>
          <span class="post-date">{formattedDate}</span>
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-tags">
          {tags?.map(tag => (
            <a href={`/blog/tag/${tag}`} class="post-tag">#{tag}</a>
          ))}
        </div>
      </div>
    </header>

    <div class="post-layout">
      <aside class="post-sidebar">
        <!-- 桌面端目录（侧边栏 sticky） -->
        <div class="desktop-toc">
          <TableOfContents headings={headings} config={config} />
        </div>

        <!-- 侧边栏广告 -->
        <AdBanner position="sidebar" config={config} />
      </aside>

      <div class="post-content">
        <!-- 移动端目录（在正文之前，可折叠） -->
        <div class="mobile-toc">
          <TableOfContents headings={headings} config={config} />
        </div>

        <!-- 邮箱订阅 -->
        <EmailSubscribe config={config} />

        <div class="prose">
          <Content />
        </div>

        <!-- 文中广告 -->
        <AdBanner position="inline" config={config} />

        <!-- 相关文章 -->
        <!-- 相关文章 -->
        {relatedPosts.length > 0 && <RelatedPosts posts={relatedPosts} config={config} />}
        <FriendLinks config={config} />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-bottom: 4rem;
  }

  .post-header {
    background: var(--bg-secondary);
    padding: 3rem 0;
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .post-category {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-color);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .post-category:hover {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin: 0 0 1rem;
    max-width: 900px;
  }

  .post-description {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    max-width: 700px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-tag {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    background: var(--bg-primary);
    border-radius: 1rem;
    transition: background 0.2s, color 0.2s;
  }

  .post-tag:hover {
    background: var(--accent-color);
    color: white;
    text-decoration: none;
  }

  .post-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 3rem;
  }

  .post-sidebar {
    position: sticky;
    top: 5rem;
    height: fit-content;
  }

  .desktop-toc {
    display: block;
  }

  .mobile-toc {
    display: none;
  }

  .post-content {
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      position: static;
      display: none;
    }

    .desktop-toc {
      display: none;
    }

    .mobile-toc {
      display: block;
    }

    .post-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 640px) {
    .post-header {
      padding: 2rem 0;
    }

    .post-title {
      font-size: 1.5rem;
    }

    .post-description {
      font-size: 1rem;
    }
  }
</style>
